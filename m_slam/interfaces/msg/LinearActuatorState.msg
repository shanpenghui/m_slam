# 推杆电机状态消息
# 电机命名，参考urdf
string name

# 电机运行状态
uint32 state 0
# 0: 空闲
# 1: 运行中
# 2: 故障
# 3: 待机

# 电机当前位置 (mm)
float32 position 0.0

# 电机当前速度 (mm/s)
float32 velocity 0.0

# 电机当前电流 (mA)
uint16 current 0

# 电机温度 (摄氏度)
uint32 temperature 0

# 故障码 (每个bit代表一种故障)
uint32 fault_code 0

# 故障码定义:
# bit0: 堵转 - 可等待5秒故障将被自动清除或使用清除故障指令，自动清除超过2次只能使用清除故障指令
# bit1: 过温 - 电机温度超过80℃，等待温度回落到60℃，自动清除
# bit2: 过流 - 电流超过限值（默认1800mA）持续3s，可等待5秒故障将被自动清除或使用清除故障指令，自动清除超过2次只能使用清除故障指令
# bit3: 电机异常 - 电缸内部输出达到最大但实际采集到的电流信息为0，当采集电流超过30mA时，自动取消电机异常提示，也可使用功能指令中的故障清除命令取消电机异常提示，一般在提示电机异常时说明电缸内马达即将达到寿命
# bit4: Flash参数错误或者未保存 - 返厂
# bit5: 电机通讯异常 - 检查通讯电机线是否断开
